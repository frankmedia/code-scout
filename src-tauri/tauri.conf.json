{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Code Scout",
  "version": "0.1.22",
  "identifier": "com.codescout.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:8080",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "Code Scout",
        "width": 1440,
        "height": 900,
        "minWidth": 960,
        "minHeight": 640,
        "resizable": true,
        "fullscreen": false,
        "decorations": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": [
      "app"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": [
      "binaries/scout-stt"
    ],
    "macOS": {
      "infoPlist": "./Info.plist",
      "entitlements": "./entitlements.plist"
    }
  },
  "plugins": {
    "shell": {
      "open": "https?://.*"
    }
  }
}
